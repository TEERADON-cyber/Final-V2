<%- include("partials/layout-top", { title: "Create Delivery Service" }) %>

<section class="card page-head">
  <h2>Create Delivery Service</h2>
  <p>Add a new delivery service type.</p>
</section>

<section class="card">
  <form class="form-grid" method="post" action="<%= rolePath('/create-delivery-service') %>">
    <div class="field">
      <label for="service_name">Delivery Service Name</label>
      <input id="service_name" name="service_name" type="text" maxlength="120" required>
    </div>

    <div class="field">
      <label for="price_rate">Price Rate (THB / kg)</label>
      <input id="price_rate" name="price_rate" type="number" step="0.01" min="0.01" required placeholder="e.g. 20">
    </div>

    <div class="actions">
      <button class="btn" type="submit">Create Delivery Service</button>
      <a class="btn secondary" href="<%= rolePath('/delivery-services') %>">Back</a>
    </div>
  </form>
</section>

<%- include("partials/layout-bottom") %>
