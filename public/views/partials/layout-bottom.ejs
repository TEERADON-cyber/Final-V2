      </main>
    </div>
  </div>
  <script>
    (function () {
      var themeToggleButtons = Array.prototype.slice.call(
        document.querySelectorAll("[data-theme-toggle]")
      );
      var html = document.documentElement;

      function setTheme(isDarkMode) {
        html.classList.toggle("dark-mode", isDarkMode);
        try {
          localStorage.setItem("theme", isDarkMode ? "dark" : "light");
        } catch (e) {
          // Ignore localStorage errors and still toggle in memory.
        }
        themeToggleButtons.forEach(function (button) {
          button.textContent = isDarkMode ? "Light Mode" : "Dark Mode";
          button.setAttribute("aria-pressed", isDarkMode ? "true" : "false");
        });
      }

      if (themeToggleButtons.length) {
        themeToggleButtons.forEach(function (button) {
          button.addEventListener("click", function () {
            setTheme(!html.classList.contains("dark-mode"));
          });
        });
        setTheme(html.classList.contains("dark-mode"));
      }

      var containers = Array.prototype.slice.call(document.querySelectorAll(".table-scroll"));
      if (!containers.length) return;

      containers.forEach(function (el) {
        var isDown = false;
        var startX = 0;
        var startScrollLeft = 0;

        el.addEventListener("pointerdown", function (event) {
          // Only handle primary button / touch / pen
          if (event.pointerType === "mouse" && event.button !== 0) return;
          isDown = true;
          startX = event.clientX;
          startScrollLeft = el.scrollLeft;
          try {
            el.setPointerCapture(event.pointerId);
          } catch (e) {
            // Ignore if capture is unsupported.
          }
        });

        el.addEventListener("pointermove", function (event) {
          if (!isDown) return;
          var dx = event.clientX - startX;
          el.scrollLeft = startScrollLeft - dx;
        });

        function endDrag() {
          isDown = false;
        }

        el.addEventListener("pointerup", endDrag);
        el.addEventListener("pointercancel", endDrag);
        el.addEventListener("pointerleave", endDrag);
      });
    })();
  </script>
 </body>
 </html>
